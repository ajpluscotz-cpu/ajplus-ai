{
  "version": 2,
  "cleanUrls": true,
  "rewrites": [
    { "source": "/api/chat", "destination": "/api/chat.js" },
    { "source": "/api/payment", "destination": "/api/payment.js" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/chat.js": { "memory": 256, "maxDuration": 15 },
    "api/payment.js": { "memory": 256, "maxDuration": 15 }
  }
}
